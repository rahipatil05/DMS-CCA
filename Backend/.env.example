# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/multi-ai-platform

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Frontend URL (CORS) — comma-separated for multiple origins
# e.g. CLIENT_URL=https://app.example.com,http://localhost:5173
CLIENT_URL=http://localhost:5173

# Groq AI (used for chat inference and admin tools)
GROQ_API_KEY=your_groq_api_key

# Email Configuration (for welcome emails & notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Multi AI Platform <your_email@gmail.com>"

# Cloudinary (for profile picture uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Legacy / Future (Optional)
GEMINI_API_KEY=your_gemini_api_key
